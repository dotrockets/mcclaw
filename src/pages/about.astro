---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
  { icon: '🔓', title: 'Open Source First', desc: 'We build on open-source and contribute back. No black boxes.' },
  { icon: '🌍', title: 'Location Independent', desc: 'Our stack works from anywhere. Built by nomads, for nomads.' },
  { icon: '💡', title: 'Radical Transparency', desc: 'Open pricing, open code, open communication. Always.' },
  { icon: '🚀', title: 'Results Over Hype', desc: 'We measure in conversions, hours saved, and ROI. Not buzzwords.' },
];
---

<BaseLayout title="About DotRockets — AI Agency from Koh Phangan" description="Our story: making enterprise AI accessible through open source. Built by digital nomads, for digital nomads.">
  <Header slot="header" />
  
  <section class="page-header">
    <div class="container">
      <h1 class="reveal">Built From a Beach<br/><span class="gradient-text">in Thailand</span></h1>
      <p class="page-sub reveal">DotRockets started with a question: What if AI agents were free?</p>
    </div>
  </section>
  
  <section class="container story reveal">
    <div class="story-content">
      <p>In 2024, Björn sat on Koh Phangan watching AI companies charge $200/month for basic automation. As a digital nomad, he knew there had to be a better way.</p>
      <p>Open-source tools existed. Self-hosting was possible. The missing piece? Someone to put it all together.</p>
      <p><strong>DotRockets was born:</strong> an AI agent agency that builds on open-source, charges once, and hands you the keys. No subscriptions. No lock-in. No bullshit.</p>
    </div>
  </section>
  
  <section class="section container">
    <h2 class="section-title reveal">Our Mission</h2>
    <p class="mission reveal">Democratize AI automation. Make enterprise-grade agents accessible to everyone.</p>
  </section>
  
  <section class="section container">
    <h2 class="section-title reveal">Our Values</h2>
    <div class="values-grid">
      {values.map(v => (
        <div class="value-card glass reveal">
          <span class="value-icon">{v.icon}</span>
          <h3>{v.title}</h3>
          <p>{v.desc}</p>
        </div>
      ))}
    </div>
  </section>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header { padding: 7rem 0 3rem; text-align: center; }
  .page-header h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.02em; }
  .page-sub { color: var(--text-secondary); margin-top: 0.75rem; font-size: 1.0625rem; }
  .story-content { max-width: 680px; margin: 0 auto; }
  .story-content p { color: var(--text-secondary); font-size: 1.125rem; line-height: 1.8; margin-bottom: 1.25rem; }
  .section { padding: 4rem 0; }
  .section-title { font-size: 1.75rem; font-weight: 700; text-align: center; margin-bottom: 2rem; }
  .mission { text-align: center; font-size: 1.25rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto; }
  .values-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; }
  .value-card { padding: 2rem; text-align: center; }
  .value-icon { font-size: 2rem; display: block; margin-bottom: 1rem; }
  .value-card h3 { font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; }
  .value-card p { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; }
</style>
