---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AgentCard from '../../components/AgentCard.astro';

const agents = [
  {
    name: 'Helios', emoji: '☀️', tagline: 'Your Spiritual Content Engine',
    description: 'Helios transforms Schumann resonance data, astrological alignments, and spiritual insights into engaging content. Built for Haus der Energien and wellness brands. Produces daily social media posts, blog articles, and newsletters — all aligned with cosmic energy patterns.',
    capabilities: ['Content Generation', 'Schumann Tracking', 'Social Media', 'SEO Optimization', 'Newsletter Creation', 'Trend Analysis'],
    color: '#f97316',
  },
  {
    name: 'Alfred', emoji: '🎩', tagline: 'Your Digital Butler',
    description: 'Alfred manages your entire digital life. Morning briefings with weather and priorities, email triage that learns your patterns, calendar optimization, and intelligent task routing. Like having a chief of staff who never sleeps and never forgets.',
    capabilities: ['Email Management', 'Calendar Optimization', 'Daily Briefings', 'Task Routing', 'Priority Scoring', 'Meeting Prep'],
    color: '#3b82f6',
  },
  {
    name: 'Research', emoji: '🔍', tagline: 'Intelligence on Demand',
    description: 'Deep web research, competitive analysis, trend monitoring, and market intelligence. Research agent scans hundreds of sources, synthesizes findings, and delivers actionable reports. Get answers backed by data, not guesses.',
    capabilities: ['Web Research', 'Competitive Analysis', 'Trend Monitoring', 'Market Reports', 'SEO Audit', 'Content Research'],
    color: '#8b5cf6',
  },
  {
    name: 'Llama', emoji: '🦙', tagline: 'Open Source. Local. Private.',
    description: 'Powered by Meta\'s Llama models running locally on your hardware. Full privacy — your data never leaves your machine. Zero API costs, unlimited usage. Perfect for sensitive business data and high-volume processing.',
    capabilities: ['Local Inference', 'Privacy-First', 'Unlimited Usage', 'Custom Fine-tuning', 'Offline Operation', 'Multi-Language'],
    color: '#22c55e',
  },
];
---

<BaseLayout title="AI Agents — Helios, Alfred & More | DotRockets" description="Meet our AI agent squad. Autonomous content creation, research, and business management.">
  <Header slot="header" />
  
  <section class="page-header">
    <div class="container">
      <h1 class="reveal">Meet the Squad</h1>
      <p class="page-sub reveal">Four AI agents. Each with a specialty. All working together to automate your business.</p>
    </div>
  </section>
  
  <section class="container">
    <div class="agents-grid">
      {agents.map(agent => <AgentCard {...agent} />)}
    </div>
  </section>
  
  <section class="section container">
    <div class="cta-card glass reveal" style="text-align: center; padding: 3rem;">
      <h2>Need a Custom Agent?</h2>
      <p style="color: var(--text-secondary); margin: 1rem 0 2rem;">We build agents tailored to your exact business needs.</p>
      <a href="/contact" class="btn btn-primary">Let's Talk →</a>
    </div>
  </section>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header { padding: 7rem 0 3rem; text-align: center; }
  .page-header h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.02em; }
  .page-sub { color: var(--text-secondary); margin-top: 0.75rem; font-size: 1.0625rem; }
  .agents-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
  .section { padding: 5rem 0; }
</style>
