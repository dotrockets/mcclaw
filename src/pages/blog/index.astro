---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Placeholder posts — will be content collection in production
const posts = [
  { slug: 'why-open-source-ai-wins', title: 'Why Open Source AI Wins in 2026', date: '2026-02-15', category: 'AI Strategy', excerpt: 'Enterprise AI platforms charge $200/month. Here\'s why open-source alternatives deliver the same results for $0.' },
  { slug: 'n8n-vs-zapier', title: 'n8n vs Zapier: The Self-Hosted Advantage', date: '2026-02-10', category: 'Automation', excerpt: 'A detailed comparison of n8n and Zapier for digital nomads who want control over their data.' },
  { slug: 'building-ai-agents-llama', title: 'Building AI Agents with Llama 3.3', date: '2026-02-05', category: 'Technical', excerpt: 'Step-by-step guide to creating autonomous AI agents using Meta\'s open-source Llama models.' },
];
---

<BaseLayout title="AI & Automation Blog | DotRockets" description="Insights on AI agents, n8n automation, digital nomad tech, and open-source tools.">
  <Header slot="header" />
  
  <section class="page-header">
    <div class="container">
      <h1 class="reveal">Blog</h1>
      <p class="page-sub reveal">Insights on AI, automation, and the open-source revolution.</p>
    </div>
  </section>
  
  <section class="container">
    <div class="posts-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-card glass reveal">
          <span class="post-category">{post.category}</span>
          <h3>{post.title}</h3>
          <p class="post-excerpt">{post.excerpt}</p>
          <span class="post-date">{post.date}</span>
        </a>
      ))}
    </div>
  </section>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header { padding: 7rem 0 3rem; text-align: center; }
  .page-header h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; }
  .page-sub { color: var(--text-secondary); margin-top: 0.75rem; }
  .posts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; }
  .post-card { padding: 2rem; display: flex; flex-direction: column; transition: all 0.2s var(--ease-out); }
  .post-card:hover { transform: translateY(-4px); border-color: var(--border-hover); }
  .post-category { font-size: 0.75rem; font-weight: 600; color: var(--brand); text-transform: uppercase; letter-spacing: 0.05em; }
  .post-card h3 { font-size: 1.25rem; font-weight: 600; margin: 0.75rem 0; }
  .post-excerpt { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; flex-grow: 1; }
  .post-date { font-size: 0.75rem; color: var(--text-tertiary); margin-top: 1rem; }
</style>
