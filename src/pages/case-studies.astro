---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Results & Case Studies | DotRockets" description="Real results: 6x conversion rates, 40h/month saved.">
  <Header slot="header" />
  
  <section class="page-header">
    <div class="container">
      <h1 class="reveal">Real Results.<br/><span class="gradient-text">Real Numbers.</span></h1>
      <p class="page-sub reveal">No fluff. Just data from actual client projects.</p>
    </div>
  </section>
  
  <section class="container">
    <article class="case-study glass reveal">
      <div class="case-header">
        <span class="case-badge">Featured</span>
        <h2>Haus der Energien</h2>
        <p class="case-sub">From 2% to 12% Conversion — How Helios Transformed Spiritual Content</p>
      </div>
      
      <div class="case-stats">
        <div class="stat"><span class="stat-value gradient-text">6×</span><span class="stat-label">Conversion Rate</span></div>
        <div class="stat"><span class="stat-value gradient-text">40h</span><span class="stat-label">Saved / Month</span></div>
        <div class="stat"><span class="stat-value gradient-text">300%</span><span class="stat-label">Engagement ↑</span></div>
      </div>
      
      <div class="case-body">
        <h3>Challenge</h3>
        <p>Manual content creation was inconsistent, time-consuming, and disconnected from the spiritual energy patterns that resonated with HdE's audience.</p>
        
        <h3>Solution</h3>
        <p>We deployed Helios — a custom AI agent that tracks Schumann resonance data, astrological alignments, and trending spiritual topics. Combined with n8n automation flows, Helios generates and publishes daily content across all channels.</p>
        
        <h3>Results</h3>
        <p>Within 3 months, conversion rates jumped from 2% to 12%. Content engagement tripled. The team saved 40+ hours per month — time now spent on personal coaching sessions instead of writing social posts.</p>
      </div>
      
      <blockquote class="case-quote">
        "It's like having a content team that understands energy. Helios doesn't just create posts — it creates the <em>right</em> posts at the <em>right</em> cosmic moment."
      </blockquote>
    </article>
  </section>
  
  <section class="section container" style="text-align: center;">
    <div class="reveal">
      <h2>Your Story Could Be Next</h2>
      <p style="color: var(--text-secondary); margin: 1rem 0 2rem;">Let's build something that delivers real results.</p>
      <a href="/contact" class="btn btn-primary">Start Your Project →</a>
    </div>
  </section>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header { padding: 7rem 0 3rem; text-align: center; }
  .page-header h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.02em; }
  .page-sub { color: var(--text-secondary); margin-top: 0.75rem; }
  .case-study { padding: 3rem; max-width: 800px; margin: 0 auto; }
  .case-badge { font-size: 0.75rem; font-weight: 600; color: var(--brand); text-transform: uppercase; letter-spacing: 0.05em; }
  .case-header h2 { font-size: 1.75rem; font-weight: 700; margin: 0.5rem 0; }
  .case-sub { color: var(--text-secondary); font-size: 1.0625rem; }
  .case-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin: 2.5rem 0; text-align: center; padding: 2rem; background: var(--bg-tertiary); border-radius: 12px; }
  .stat-value { font-size: 2rem; font-weight: 700; display: block; }
  .stat-label { font-size: 0.8125rem; color: var(--text-tertiary); font-weight: 500; }
  .case-body h3 { font-size: 1.125rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .case-body p { color: var(--text-secondary); line-height: 1.7; }
  .case-quote { margin-top: 2rem; padding: 1.5rem; border-left: 3px solid var(--brand); font-style: italic; color: var(--text-secondary); line-height: 1.6; }
  .section { padding: 5rem 0; }
</style>
