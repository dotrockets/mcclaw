---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const channels = [
  { icon: '💬', title: 'Telegram', desc: 'Fastest response. Usually within hours.', link: 'https://t.me/dotrockets', cta: 'Message on Telegram' },
  { icon: '📧', title: 'Email', desc: 'For detailed inquiries and proposals.', link: 'mailto:hello@dotrockets.space', cta: 'Send Email' },
  { icon: '📅', title: 'Video Call', desc: 'Book a free 30-minute strategy session.', link: '#calendly', cta: 'Book a Call' },
  { icon: '🐙', title: 'GitHub', desc: 'Check out our open-source projects.', link: 'https://github.com/dotrockets', cta: 'View GitHub' },
];
---

<BaseLayout title="Contact DotRockets — Telegram, Email, Calendly" description="Get in touch. We respond within 24 hours.">
  <Header slot="header" />
  
  <section class="page-header">
    <div class="container">
      <h1 class="reveal">Let's Build Something</h1>
      <p class="page-sub reveal">Choose your preferred channel. We respond within 24 hours.</p>
    </div>
  </section>
  
  <section class="container">
    <div class="channels-grid">
      {channels.map(ch => (
        <a href={ch.link} class="channel-card glass reveal" target={ch.link.startsWith('http') ? '_blank' : undefined} rel={ch.link.startsWith('http') ? 'noopener' : undefined}>
          <span class="channel-icon">{ch.icon}</span>
          <h3>{ch.title}</h3>
          <p>{ch.desc}</p>
          <span class="channel-cta">{ch.cta} →</span>
        </a>
      ))}
    </div>
  </section>
  
  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header { padding: 7rem 0 3rem; text-align: center; }
  .page-header h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; }
  .page-sub { color: var(--text-secondary); margin-top: 0.75rem; }
  .channels-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto; }
  .channel-card { padding: 2rem; text-align: center; transition: all 0.2s var(--ease-out); display: block; }
  .channel-card:hover { transform: translateY(-4px); border-color: var(--border-hover); }
  .channel-icon { font-size: 2rem; display: block; margin-bottom: 1rem; }
  .channel-card h3 { font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem; }
  .channel-card p { font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 1rem; }
  .channel-cta { font-size: 0.875rem; color: var(--brand); font-weight: 500; }
</style>
